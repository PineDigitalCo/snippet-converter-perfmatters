{
  "name": "snippet-converter-for-perfmatters/plugin",
  "description": "Convert third-party code snippet JSON exports into Perfmatters PMCS import format.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^2.1",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "phpstan/extension-installer": "^1.4",
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "SnippetConverterForPerfmatters\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SnippetConverterForPerfmatters\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "analyse": "@php vendor/bin/phpstan analyse --memory-limit=1G",
    "phpcs": "@php vendor/bin/phpcs",
    "test": "@php vendor/bin/phpunit -c phpunit.xml.dist",
    "lint": [
      "@analyse",
      "@phpcs"
    ],
    "dist-zip": "bash bin/build-dist-zip.sh"
  }
}
